# === LLM 配置 (DeepSeek / OpenAI 兼容) ===
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_MODEL=deepseek-chat

# === 辩论配置 ===
MAX_DEBATE_ROUNDS=3
TEMPERATURE=0.7
MAX_TOKENS=2048

# === 数据源 ===
# 可选: fmp (默认), yfinance, sample
DATA_SOURCE=fmp
FMP_API_KEY=your_fmp_api_key_here
